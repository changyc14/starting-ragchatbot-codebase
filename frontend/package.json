{
  "name": "ragchatbot-frontend",
  "version": "1.0.0",
  "description": "Frontend for RAG Chatbot",
  "private": true,
  "scripts": {
    "format": "prettier --write \"*.{js,css,html}\"",
    "format:check": "prettier --check \"*.{js,css,html}\"",
    "lint": "eslint *.js",
    "lint:fix": "eslint --fix *.js",
    "quality": "npm run format:check && npm run lint"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  }
}